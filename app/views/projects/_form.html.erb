<%# Shared project form. The split publish button (below) drives the
    status + scheduled_at fields via the publish-form Stimulus controller. %>
<%= simple_form_for @project, html: { data: {
      controller: "publish-form load-button",
      "publish-form-current-status-value": (@project.persisted? ? @project.status : "draft")
    } } do |f| %>
  <%= f.input :title, label: "Project Title", hint: "Capitalize the appropriate letters manually." %>
  <%= f.input :personal_project, label: "Personal Project" %>
  <%= f.input :private_repo, label: "Private Github Repo" %>
  <!-- Featured project start -->
  <%= f.input :featured, label: "Featured Project", hint: "Have up to 3 featured personal projects and 3 featured open source projects at anyone time for optimal homepage layout." %>
  <p class="text muted small">Featured <span class="text-decoration-underline">Personal</span> Projects: <span class="text-success"><%= @featured_personal_projects_count %></span> <span class="text-dark">/ 3</span> | Featured <span class="text-decoration-underline">Open Source</span> Projects: <span class="text-success"><%= @featured_open_source_projects_count %></span> <span class="text-dark">/ 3</span> = <span class="text-decoration-underline">Total</span> Featured Projects: <span class="text-primary"><%= @featured_personal_projects_count + @featured_open_source_projects_count %></span> <span class="text-dark">/ 6</span></p>
  <!-- Featured project end -->
  <%= f.input :description, as: :text, label: "Project Description", hint: "If more than 2 'non-personal' projects, describe briefly open source contribution focus." %>
  <%= f.input :tech_stack, label: "Tech Stack", hint: "Show 3-6 main technologies (capitalized) and separating each one with ' . '", placeholder: "Ruby-on-Rails . Bootstrap . StimulusJS . PostgreSQL . Active Record" %>
  <%= f.input :img_url, label: "Image URL", hint: "Preference is to use images already in the project folder (file extensions must be included eg. .svg, .jpg, .png). Careful ! Typos will break the app. Can also use an external URL.", placeholder: "<name-feature-screenshot> eg. sipfolio-cocktail-screenshot" %>
  <%= f.input :featured_image, as: :file, label: "Featured Image Upload", hint: "Optional. Upload an image file (stored on Cloudinary in production). Takes precedence over a URL when both are set." %>
  <%= f.input :github_url, label: "Github URL", placeholder: "https://github.com/louiskb/rails-mister-cocktail", hint: "Prefix 'https://'" %>
  <%= f.input :project_url, label: "Project URL", placeholder: "https://www.sipfolio.rocks", hint: "Prefix 'https://'" %>
  <%# Hidden fields driven by the split button via the publish-form controller. %>
  <input type="hidden"
         name="project[status]"
         value="<%= @project.persisted? ? @project.status : "draft" %>"
         data-publish-form-target="statusInput">
  <input type="hidden"
         name="project[scheduled_at]"
         value="<%= @project.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
         data-publish-form-target="scheduledAtInput">

  <%# ===== SPLIT PUBLISH BUTTON ===== %>
  <div class="d-flex align-items-center gap-3 flex-wrap my-4" data-load-button-target="buttons">
    <% if @project.persisted? %>
      <% if @project.scheduled? %>
        <p class="small text-warning w-100 mb-1">
          <i class="fa-regular fa-clock me-1"></i>
          Scheduled to publish on <%= @project.scheduled_at.strftime("%d %b %Y at %H:%M") %>
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% elsif @project.published? %>
        <p class="small text-success w-100 mb-1">
          <i class="fa-solid fa-circle-check me-1"></i>
          This project is published and visible to everyone
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% else %>
        <p class="small text-muted w-100 mb-1">
          <i class="fa-regular fa-file-lines me-1"></i>
          This project is a draft and not visible to the public
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% end %>
    <% end %>

    <div class="btn-group dropup">
      <%# Default action button — context-aware label. %>
      <% if @project.new_record? %>
        <button type="button" class="btn btn-primary rounded-start-4"
                data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                data-load-button-loading-text-value="Saving...">
          Save as draft
        </button>
      <% else %>
        <button type="button" class="btn btn-primary rounded-start-4"
                data-action="click->load-button#showSpinner click->publish-form#saveChanges"
                data-load-button-loading-text-value="Saving changes...">
          Save changes
        </button>
      <% end %>

      <%# Chevron — opens the upward dropdown. %>
      <button type="button"
              class="btn btn-primary dropdown-toggle dropdown-toggle-split rounded-end-4"
              data-bs-toggle="dropdown"
              aria-expanded="false">
        <span class="visually-hidden">More publishing options</span>
      </button>

      <ul class="dropdown-menu dropdown-menu-end">
        <% unless @project.new_record? %>
          <li>
            <button type="button" class="dropdown-item"
                    data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                    data-load-button-loading-text-value="Saving...">
              <i class="fa-regular fa-file me-2 text-muted"></i>Save as draft
            </button>
          </li>
          <li><hr class="dropdown-divider"></li>
        <% end %>
        <li>
          <button type="button" class="dropdown-item"
                  data-action="click->load-button#showSpinner click->publish-form#publishNow"
                  data-load-button-loading-text-value="Publishing...">
            <i class="fa-solid fa-globe me-2 text-muted"></i>Publish now
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item"
                  data-bs-toggle="modal" data-bs-target="#schedulePostModal">
            <i class="fa-regular fa-clock me-2 text-muted"></i>Schedule&hellip;
          </button>
        </li>
      </ul>
    </div>

    <%= link_to "Cancel", projects_path, class: "btn btn-outline-dark rounded-4 p-2" %>
  </div>

  <%# ===== SCHEDULE MODAL ===== %>
  <div class="modal fade" id="schedulePostModal" tabindex="-1"
       aria-labelledby="schedulePostModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="schedulePostModalLabel">
            <i class="fa-regular fa-clock me-2"></i>Schedule project
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted mb-3">Choose when this project will go live automatically.</p>
          <label class="form-label fw-semibold" for="schedule-post-datetime">Publish at</label>
          <%# No `name` attribute: this field is read by the publish-form controller,
              which copies its value into the hidden scheduled_at input above. %>
          <input type="datetime-local"
                 id="schedule-post-datetime"
                 class="form-control"
                 min="<%= Time.current.strftime("%Y-%m-%dT%H:%M") %>"
                 value="<%= @project.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
                 data-publish-form-target="scheduleInput"
                 required>
          <div class="form-text">
            <i class="fa-solid fa-clock me-1"></i>Times are in <strong><%= Time.current.zone %></strong>.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary"
                  data-action="click->load-button#showSpinner click->publish-form#confirmSchedule"
                  data-load-button-loading-text-value="Scheduling...">
            Schedule project
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
