<% content_for :title, "Revise with AI — #{@blog_post.title}" %>

<div class="container py-5">
  <div class="row justify-content-center">
    <div class="col-lg-8">
      <nav aria-label="breadcrumb" class="mb-4">
        <ol class="breadcrumb">
          <li class="breadcrumb-item"><%= link_to "Blog", blog_posts_path %></li>
          <li class="breadcrumb-item"><%= link_to @blog_post.title, @blog_post %></li>
          <li class="breadcrumb-item active" aria-current="page">Revise with AI</li>
        </ol>
      </nav>

      <div class="mb-4">
        <h1 class="mb-2"><i class="fa-solid fa-wand-magic-sparkles me-2"></i>Revise with AI</h1>
        <p class="text-muted mb-0"><%= @blog_post.title %></p>
      </div>

      <% if ai_configured? %>
        <% if flash[:alert] %>
          <div class="alert alert-danger mb-4"><%= flash[:alert] %></div>
        <% end %>

        <% if @has_rich_text_body %>
          <div class="alert alert-info">
            <i class="fa-solid fa-circle-info me-2"></i>
            This post currently uses the rich-text editor. Revising it with AI will replace the
            editor content with AI-generated HTML.
          </div>
        <% end %>

        <%# Current content preview — collapsed by default. %>
        <div class="mb-4">
          <a class="d-inline-flex align-items-center gap-2 text-decoration-none"
             data-bs-toggle="collapse" href="#currentContentPreview" role="button"
             aria-expanded="false" aria-controls="currentContentPreview">
            <span class="small fw-semibold text-uppercase">Current content</span>
            <i class="fa-solid fa-chevron-down small"></i>
          </a>
          <div class="collapse mt-2" id="currentContentPreview">
            <div class="border rounded p-3" style="max-height: 300px; overflow-y: auto; font-size: 0.875rem;">
              <% if @blog_post.html_content.present? %>
                <%= sanitize @blog_post.html_content %>
              <% elsif @blog_post.body.present? %>
                <%= @blog_post.body %>
              <% else %>
                <p class="text-muted fst-italic mb-0">No content yet.</p>
              <% end %>
            </div>
          </div>
        </div>

        <%= simple_form_for :blog_post, url: revise_with_ai_blog_post_path(@blog_post), method: :patch,
              html: { multipart: true } do |f| %>

          <%= f.input :prompt, as: :text,
                input_html: { rows: 5, value: @prompt },
                label: "How should the AI revise this post?",
                hint: "Describe the changes you'd like — the AI will preserve the rest." %>

          <% if @blog_post.featured_image.attached? || @blog_post.img_url.present? %>
            <div class="form-check mb-3">
              <%= check_box_tag "blog_post[keep_featured_image]", "1", false,
                    class: "form-check-input", id: "blog_post_keep_featured_image" %>
              <%= label_tag "blog_post_keep_featured_image", "Keep the current image", class: "form-check-label" %>
            </div>
            <p class="form-text">
              By default the AI fetches a fresh Unsplash photo. Tick the box to keep the current image,
              or upload a replacement below (uploading always wins).
            </p>
          <% end %>

          <%= f.input :featured_image, as: :file,
                label: "Replace featured image (optional)",
                input_html: { accept: "image/*" },
                hint: "Upload a photo to use instead of the AI's Unsplash pick." %>

          <%= f.input :image_url,
                label: "Fallback image URL (optional)",
                input_html: { value: @blog_post.img_url },
                hint: "Used only if no upload and the Unsplash fetch fails." %>

          <%# Keep the post's current status on revision (Phase 4 adds scheduling UI). %>
          <%= f.hidden_field :status, value: @blog_post.status %>

          <div class="d-flex gap-3 my-4">
            <%= f.button :submit, "Revise post", class: "btn btn-primary rounded-4 p-2" %>
            <%= link_to "Cancel", @blog_post, class: "btn btn-outline-dark rounded-4 p-2" %>
          </div>
        <% end %>
      <% else %>
        <%= render "ai_not_configured" %>
      <% end %>
    </div>
  </div>
</div>
