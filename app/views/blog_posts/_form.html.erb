<%# Shared blog post form. The split publish button (below) drives the
    status + scheduled_at fields via the publish-form Stimulus controller. %>
<%= simple_form_for @blog_post, html: { multipart: true, data: {
      controller: "publish-form load-button",
      "publish-form-current-status-value": (@blog_post.persisted? ? @blog_post.status : "draft")
    } } do |f| %>
  <%= f.error_notification %>
  <%= f.error_notification message: f.object.errors[:base].to_sentence if f.object.errors[:base].present? %>

  <%= f.input :title, label: "Blog Post Title", hint: "Make the title 3-4 words long for optimal blog post card height. Capitalize the beginning of each word." %>

  <%= f.input :blog_excerpt, as: :text, input_html: { rows: 3 }, label: "Excerpt", hint: "A 1–2 sentence preview shown on the blog cards. Falls back to the description if left blank." %>

  <%= f.input :description, as: :text, label: "Blog Post Description", hint: "Make the description 30-40 words long to optimally fill out the blog post cards." %>

  <%= f.input :img_url, label: "Featured Image URL", hint: "Use image aspect ratio 3:2 (w:h). Preference is to use images already in the project folder (file extensions must be included eg. .svg, .jpg, .png). Careful! Typos will break the app. Can also use an external URL starting with HTTPS://", placeholder: "abstract-waves" %>
  <%= f.input :featured_image, as: :file, label: "Featured Image Upload", hint: "Optional. Upload an image file (stored on Cloudinary in production). Takes precedence over a URL when both are set.", input_html: { accept: "image/*" } %>
  <%= f.input :featured_image_caption, label: "Featured Image Caption", hint: "Optional caption/credit shown under the featured image." %>
  <%= f.input :featured, as: :boolean, label: "Featured Blog Post", hint: "Highlight this post on the blog." %>

  <%# ===== CONTENT — use EITHER the rich text editor OR the HTML field, never both ===== %>
  <div class="mb-4">
    <%= f.label :body, "Content (rich text editor)", class: "form-label fw-semibold" %>
    <small class="text-muted d-block mb-2">
      Write a manual post here with the editor. Use this <strong>or</strong> the HTML field below — a post can't have both.
    </small>
    <%= f.rich_text_area :body %>
  </div>

  <%= f.input :html_content, as: :text, rows: 12, label: "HTML Code For Your Blog Post (advanced/AI posts)", hint: "Leave blank if you used the rich text editor above. Guide: (1) Use single quotes ' ' for HTML attribute values and escape any apostrophes inside with a 'backslash' in front, (2) can use bootstrap and custom classes as well as inline styles, (3) the <style> element doesn't work and is meant to be in the <head>, (4) the attribute target='_blank' attribute doesn't work and may be sanitized, (5) adding plain text without any HTML won't break the web app, (6) your HTML code is already wrapped inside the following elements: <div class='container'><article>[YOUR CODE]</article></div>, (7) keep to a consistent style & familiar structure, (8) start the blog post with a <h2> tag (<h1> is already used once at the top of the page), (9) no <script> elements, and (10) optimize it for SEO.", placeholder: "<h2 class='text-primary'>Ruby on Rails History</h2>" %>

  <%# ===== TAGS ===== %>
  <div class="mb-4 mt-4" data-controller="tag-manager">
    <label class="form-label fw-semibold">Tags</label>
    <p class="form-text mb-3">
      Tags let visitors filter blog posts. Tick a box to attach a tag to this post, use the field below to add a new tag, or the &times; to delete one globally.
    </p>

    <%# Existing tags as checkboxes %>
    <div class="tag-manager-list mb-3 d-flex flex-wrap gap-3" data-tag-manager-target="tagList">
      <% @all_tags.each do |tag| %>
        <div class="tag-checkbox-item" data-tag-id="<%= tag.id %>">
          <label class="tag-checkbox-label">
            <%= check_box_tag "blog_post[tag_ids][]", tag.id,
                  @blog_post.tag_ids.include?(tag.id),
                  id: "tag_#{tag.id}",
                  class: "tag-checkbox-input" %>
            <span class="tag-checkbox-name"><%= tag.name %></span>
          </label>
          <button type="button"
                  class="tag-delete-btn btn btn-sm btn-link text-danger p-0 ms-1"
                  title="Delete tag globally"
                  data-action="click->tag-manager#deleteTag"
                  data-tag-id="<%= tag.id %>">
            <i class="fa-solid fa-xmark"></i>
          </button>
        </div>
      <% end %>
      <% if @all_tags.empty? %>
        <p class="text-muted small tag-manager-empty">No tags yet. Add one below.</p>
      <% end %>
    </div>

    <%# Inline tag creator %>
    <div class="tag-creator d-flex gap-2 align-items-center">
      <input type="text"
             class="form-control form-control-sm tag-creator-input"
             placeholder="New tag name…"
             data-tag-manager-target="nameInput"
             data-action="keydown.enter->tag-manager#addTag:prevent">
      <button type="button"
              class="btn btn-outline-dark btn-sm text-nowrap"
              data-action="click->tag-manager#addTag"
              data-tag-manager-target="addButton">
        <i class="fa-solid fa-plus me-1"></i>Add tag
      </button>
    </div>
    <p class="form-text mt-1 mb-0 tag-creator-hint" data-tag-manager-target="hint"></p>
  </div>

  <%# Ensure empty tag_ids clears previous associations when no boxes are checked %>
  <input type="hidden" name="blog_post[tag_ids][]" value="">

  <%# Hidden fields driven by the split button via the publish-form controller. %>
  <input type="hidden"
         name="blog_post[status]"
         value="<%= @blog_post.persisted? ? @blog_post.status : "draft" %>"
         data-publish-form-target="statusInput">
  <input type="hidden"
         name="blog_post[scheduled_at]"
         value="<%= @blog_post.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
         data-publish-form-target="scheduledAtInput">

  <%# ===== SPLIT PUBLISH BUTTON ===== %>
  <div class="d-flex align-items-center gap-3 flex-wrap my-4" data-load-button-target="buttons">
    <% if @blog_post.persisted? %>
      <% if @blog_post.scheduled? %>
        <p class="small text-warning w-100 mb-1">
          <i class="fa-regular fa-clock me-1"></i>
          Scheduled to publish on <%= @blog_post.scheduled_at&.strftime("%d %b %Y at %H:%M") %>
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% elsif @blog_post.published? %>
        <p class="small text-success w-100 mb-1">
          <i class="fa-solid fa-circle-check me-1"></i>
          This post is published and visible to everyone
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% else %>
        <p class="small text-muted w-100 mb-1">
          <i class="fa-regular fa-file-lines me-1"></i>
          This post is a draft and not visible to the public
          &mdash; use the dropdown to reschedule or change status.
        </p>
      <% end %>
    <% end %>

    <div class="btn-group dropup">
      <%# Default action button — context-aware label. %>
      <% if @blog_post.new_record? %>
        <button type="button" class="btn btn-primary rounded-start-4"
                data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                data-load-button-loading-text-value="Saving...">
          Save as draft
        </button>
      <% else %>
        <button type="button" class="btn btn-primary rounded-start-4"
                data-action="click->load-button#showSpinner click->publish-form#saveChanges"
                data-load-button-loading-text-value="Saving changes...">
          Save changes
        </button>
      <% end %>

      <%# Chevron — opens the upward dropdown. %>
      <button type="button"
              class="btn btn-primary dropdown-toggle dropdown-toggle-split rounded-end-4"
              data-bs-toggle="dropdown"
              aria-expanded="false">
        <span class="visually-hidden">More publishing options</span>
      </button>

      <ul class="dropdown-menu dropdown-menu-end">
        <% unless @blog_post.new_record? %>
          <li>
            <button type="button" class="dropdown-item"
                    data-action="click->load-button#showSpinner click->publish-form#saveDraft"
                    data-load-button-loading-text-value="Saving...">
              <i class="fa-regular fa-file me-2 text-muted"></i>Save as draft
            </button>
          </li>
          <li><hr class="dropdown-divider"></li>
        <% end %>
        <li>
          <button type="button" class="dropdown-item"
                  data-action="click->load-button#showSpinner click->publish-form#publishNow"
                  data-load-button-loading-text-value="Publishing...">
            <i class="fa-solid fa-globe me-2 text-muted"></i>Publish now
          </button>
        </li>
        <li>
          <button type="button" class="dropdown-item"
                  data-bs-toggle="modal" data-bs-target="#schedulePostModal">
            <i class="fa-regular fa-clock me-2 text-muted"></i>Schedule&hellip;
          </button>
        </li>
      </ul>
    </div>

    <%= link_to "Cancel", blog_posts_path, class: "btn btn-outline-dark rounded-4 p-2" %>
  </div>

  <%# ===== SCHEDULE MODAL ===== %>
  <div class="modal fade" id="schedulePostModal" tabindex="-1"
       aria-labelledby="schedulePostModalLabel" aria-hidden="true">
    <div class="modal-dialog">
      <div class="modal-content">
        <div class="modal-header">
          <h5 class="modal-title" id="schedulePostModalLabel">
            <i class="fa-regular fa-clock me-2"></i>Schedule post
          </h5>
          <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
        </div>
        <div class="modal-body">
          <p class="text-muted mb-3">Choose when this post will go live automatically.</p>
          <label class="form-label fw-semibold" for="schedule-post-datetime">Publish at</label>
          <%# No `name` attribute: this field is read by the publish-form controller,
              which copies its value into the hidden scheduled_at input above. %>
          <input type="datetime-local"
                 id="schedule-post-datetime"
                 class="form-control"
                 min="<%= Time.current.strftime("%Y-%m-%dT%H:%M") %>"
                 value="<%= @blog_post.scheduled_at&.strftime("%Y-%m-%dT%H:%M") %>"
                 data-publish-form-target="scheduleInput"
                 required>
          <div class="form-text">
            <i class="fa-solid fa-clock me-1"></i>Times are in <strong><%= Time.current.zone %></strong>.
          </div>
        </div>
        <div class="modal-footer">
          <button type="button" class="btn btn-outline-dark" data-bs-dismiss="modal">Cancel</button>
          <button type="button" class="btn btn-primary"
                  data-action="click->load-button#showSpinner click->publish-form#confirmSchedule"
                  data-load-button-loading-text-value="Scheduling...">
            Schedule post
          </button>
        </div>
      </div>
    </div>
  </div>
<% end %>
