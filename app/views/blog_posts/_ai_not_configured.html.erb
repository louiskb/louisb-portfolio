<%# Friendly notice shown on the AI pages when no Anthropic API key is set. %>
<div class="alert alert-warning" role="alert">
  <h2 class="h5 mb-2"><i class="fa-solid fa-robot me-2"></i>AI is not configured yet</h2>
  <p class="mb-2">
    AI blog generation needs an Anthropic API key. Set the
    <code>ANTHROPIC_API_KEY</code> environment variable to enable it. Until then,
    you can still write posts manually.
  </p>
  <div class="d-flex gap-2">
    <%= link_to "Write manually instead", new_blog_post_path, class: "btn btn-primary btn-sm rounded-4" %>
    <%= link_to "Back to blog", blog_posts_path, class: "btn btn-outline-dark btn-sm rounded-4" %>
  </div>
</div>
